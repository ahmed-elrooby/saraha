<!-- ===== PROFILE PAGE – WITHOUT PHOTO ===== -->
<%- include("navbar.ejs") %>

<section class="profile-section" dir="rtl">
  <!-- Particles Canvas -->
  <canvas id="particlesCanvasProfile"></canvas>

  <!-- Floating Shapes -->
  <div class="floating-shape shape-1"></div>
  <div class="floating-shape shape-2"></div>
  <div class="floating-shape shape-3"></div>
  <div class="floating-shape shape-4"></div>
  <div class="floating-shape shape-5"></div>

  <div class="container position-relative" style="z-index: 10">
    <!-- ===== PROFILE CARD (no photo) ===== -->
    <div class="row justify-content-center">
      <div class="col-lg-6 col-md-8 col-12">
        <div class="profile-card-wrapper" id="cardWrapperProfile">
          <div class="profile-card text-center" id="profileCard">
            <!-- Icon instead of avatar -->
            <div class="profile-icon-wrapper">
              <div class="profile-icon-glow"></div>
              <div class="profile-icon">
                <i class="fas fa-user-circle"></i>
              </div>
            </div>

            <!-- Username -->
            <h3 class="profile-username mt-3">
              <span class="gradient-text"><%= userName %></span>
            </h3>

            <!-- Share Button -->
            <button
              data-toggle="modal"
              data-target="#shareModal"
              class="btn btn-share-profile pulse-on-hover"
            >
              <i class="fas fa-share-alt me-2"></i> مشاركة الملف الشخصي
            </button>

            <div class="profile-divider mx-auto my-4"></div>

            <p class="profile-helper">
              <i class="fas fa-user-check me-1"></i>
              يمكن لأصدقائك مشاركة ملاحظاتهم معك من خلال هذا الرابط
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== MESSAGES SECTION ===== -->
    <div class="row justify-content-center mt-5">
      <div class="col-lg-8 col-md-10 col-12">
        <div class="messages-card">
          <div class="messages-header">
            <h4 class="messages-title">
              <i class="fas fa-comment-dots me-2"></i> رسائلك
            </h4>
            <span class="messages-badge"><%= messages ? messages.length : 0 %></span>
          </div>

          <div class="messages-body">
            <% if (messages && messages.length > 0) { %>
              <% for (let message of messages) { %>
                <div class="message-item glass-message">
                  <div class="message-content">
                    <p><%= message.message %></p>
                  </div>
                  <div class="message-meta">
                    <span class="message-date">
                      <i class="far fa-clock me-1"></i>
                      <%= new Date().toLocaleDateString('ar-EG') %>
                    </span>
                  </div>
                </div>
              <% } %>
            <% } else { %>
              <div class="empty-state">
                <i class="fas fa-inbox fa-3x mb-3"></i>
                <p>لا توجد رسائل بعد...</p>
                <span class="empty-sub">شارك ملفك الشخصي مع أصدقائك لتلقي الملاحظات</span>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     MODAL – SHARE PROFILE (only)
     ============================================================ -->
<div
  class="modal fade"
  id="shareModal"
  tabindex="-1"
  aria-labelledby="shareModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content glass-modal">
      <div class="modal-header">
        <h5 class="modal-title" id="shareModalLabel">
          <i class="fas fa-share-alt me-2"></i> مشاركة الملف الشخصي
        </h5>
        <button
          type="button"
          class="close"
          data-dismiss="modal"
          aria-label="Close"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <p class="share-url-label">رابط ملفك الشخصي:</p>
        <div class="share-url-box">
          <a href="<%= fullurl + '/user/' + userId %>" target="_blank">
            <i class="fas fa-link me-2"></i>
            <%= fullurl + '/user/' + userId %>
          </a>
        </div>
        <button class="btn btn-copy-link mt-3" id="copyLinkBtn">
          <i class="fas fa-copy me-2"></i> نسخ الرابط
        </button>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-modal-secondary" data-dismiss="modal">
          إغلاق
        </button>
      </div>
    </div>
  </div>
</div>

<%- include("footer.ejs") %>

<style>
  /* ============================================================
     BASE
     ============================================================ */
  .profile-section {
    position: relative;
    min-height: 100vh;
    padding: 4rem 0 6rem;
    background: #0a0a1a;
    overflow: hidden;
    isolation: isolate;
  }

  /* ============================================================
     CANVAS
     ============================================================ */
  #particlesCanvasProfile {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ============================================================
     FLOATING SHAPES
     ============================================================ */
  .floating-shape {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 1;
    will-change: transform;
    opacity: 0.35;
    animation: floatShape 14s ease-in-out infinite alternate;
  }

  .shape-1 {
    width: 300px;
    height: 300px;
    top: -8%;
    right: -3%;
    background: radial-gradient(circle, rgba(108, 99, 255, 0.18) 0%, transparent 70%);
    animation-delay: 0s;
    animation-duration: 16s;
  }
  .shape-2 {
    width: 220px;
    height: 220px;
    bottom: 5%;
    left: -4%;
    background: radial-gradient(circle, rgba(255, 107, 107, 0.15) 0%, transparent 70%);
    animation-delay: -3s;
    animation-duration: 18s;
  }
  .shape-3 {
    width: 160px;
    height: 160px;
    top: 30%;
    left: 6%;
    background: radial-gradient(circle, rgba(0, 230, 118, 0.12) 0%, transparent 70%);
    animation-delay: -5s;
    animation-duration: 14s;
  }
  .shape-4 {
    width: 130px;
    height: 130px;
    bottom: 35%;
    right: 5%;
    background: radial-gradient(circle, rgba(255, 215, 0, 0.12) 0%, transparent 70%);
    animation-delay: -7s;
    animation-duration: 17s;
  }
  .shape-5 {
    width: 100px;
    height: 100px;
    top: 55%;
    left: 2%;
    background: radial-gradient(circle, rgba(0, 188, 212, 0.15) 0%, transparent 70%);
    animation-delay: -9s;
    animation-duration: 13s;
  }

  @keyframes floatShape {
    0% {
      transform: translate(0, 0) scale(1) rotate(0deg);
    }
    33% {
      transform: translate(28px, -22px) scale(1.07) rotate(6deg);
    }
    66% {
      transform: translate(-20px, 28px) scale(0.93) rotate(-5deg);
    }
    100% {
      transform: translate(14px, -10px) scale(1.04) rotate(4deg);
    }
  }

  /* ============================================================
     PROFILE CARD
     ============================================================ */
  .profile-card-wrapper {
    position: relative;
    z-index: 10;
    perspective: 1200px;
  }

  .profile-card {
    position: relative;
    z-index: 20;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(32px) saturate(1.4);
    -webkit-backdrop-filter: blur(32px) saturate(1.4);
    border-radius: 3.5rem;
    padding: 3.5rem 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow:
      0 40px 80px rgba(0, 0, 0, 0.6),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition: transform 0.2s ease-out, box-shadow 0.4s ease;
    transform-style: preserve-3d;
  }

  .profile-card:hover {
    box-shadow:
      0 60px 120px rgba(0, 0, 0, 0.7),
      inset 0 1px 0 rgba(255, 255, 255, 0.07);
  }

  /* ============================================================
     PROFILE ICON (instead of avatar)
     ============================================================ */
  .profile-icon-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    width: 120px;
    height: 120px;
  }

  .profile-icon-glow {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(108, 99, 255, 0.4), rgba(108, 99, 255, 0.05));
    filter: blur(22px);
    opacity: 0.6;
    animation: pulseGlow 3s ease-in-out infinite alternate;
  }

  @keyframes pulseGlow {
    0% {
      opacity: 0.4;
      transform: scale(0.95);
    }
    100% {
      opacity: 1;
      transform: scale(1.1);
    }
  }

  .profile-icon {
    position: relative;
    z-index: 2;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6c63ff, #8b83ff);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    color: #fff;
    box-shadow: 0 12px 40px rgba(108, 99, 255, 0.3);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .profile-card:hover .profile-icon {
    transform: scale(1.04);
    box-shadow: 0 16px 56px rgba(108, 99, 255, 0.5);
  }

  /* ============================================================
     USERNAME
     ============================================================ */
  .profile-username {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 0.25rem;
  }

  .gradient-text {
    background: linear-gradient(135deg, #6c63ff 0%, #a78bfa 40%, #f472b6 70%, #fb923c 100%);
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradientShift 6s ease-in-out infinite alternate;
  }

  @keyframes gradientShift {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  /* ============================================================
     SHARE BUTTON
     ============================================================ */
  .btn-share-profile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 2.2rem;
    border-radius: 60px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    pointer-events: auto;
    transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    border: 1.5px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.04);
    color: #fff;
    backdrop-filter: blur(6px);
    text-decoration: none;
    gap: 0.4rem;
  }

  .btn-share-profile:hover {
    transform: translateY(-3px) scale(1.02);
    border-color: rgba(108, 99, 255, 0.5);
    background: rgba(108, 99, 255, 0.08);
    box-shadow: 0 12px 40px rgba(108, 99, 255, 0.15);
    color: #fff;
  }

  .btn-share-profile:active {
    transform: translateY(0) scale(0.98);
  }

  .pulse-on-hover {
    position: relative;
    overflow: hidden;
  }

  .pulse-on-hover::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 60px;
    background: rgba(255, 255, 255, 0.05);
    transform: scale(0.8);
    opacity: 0;
    transition: transform 0.5s ease, opacity 0.5s ease;
    pointer-events: none;
  }

  .pulse-on-hover:hover::after {
    transform: scale(1);
    opacity: 1;
  }

  /* ============================================================
     PROFILE DIVIDER
     ============================================================ */
  .profile-divider {
    width: 60px;
    height: 2.5px;
    border-radius: 4px;
    background: linear-gradient(90deg, transparent, rgba(108, 99, 255, 0.5), transparent);
  }

  .profile-helper {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.01em;
  }

  .profile-helper i {
    color: rgba(108, 99, 255, 0.4);
  }

  /* ============================================================
     MESSAGES CARD
     ============================================================ */
  .messages-card {
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(24px) saturate(1.3);
    -webkit-backdrop-filter: blur(24px) saturate(1.3);
    border-radius: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
    overflow: hidden;
    transition: box-shadow 0.4s ease;
  }

  .messages-card:hover {
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.5);
  }

  .messages-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .messages-title {
    color: rgba(255, 255, 255, 0.85);
    font-weight: 600;
    font-size: 1.1rem;
    margin: 0;
  }

  .messages-title i {
    color: rgba(108, 99, 255, 0.5);
  }

  .messages-badge {
    background: rgba(108, 99, 255, 0.15);
    color: #a78bfa;
    padding: 0.2rem 0.9rem;
    border-radius: 30px;
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px solid rgba(108, 99, 255, 0.1);
  }

  .messages-body {
    padding: 1.5rem 2rem;
    max-height: 460px;
    overflow-y: auto;
  }

  .messages-body::-webkit-scrollbar {
    width: 4px;
  }

  .messages-body::-webkit-scrollbar-track {
    background: transparent;
  }

  .messages-body::-webkit-scrollbar-thumb {
    background: rgba(108, 99, 255, 0.3);
    border-radius: 10px;
  }

  /* ============================================================
     MESSAGE ITEMS
     ============================================================ */
  .message-item {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 1.2rem;
    padding: 1.2rem 1.5rem;
    margin-bottom: 0.8rem;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .message-item:last-child {
    margin-bottom: 0;
  }

  .message-item:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(108, 99, 255, 0.1);
  }

  .message-content p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.95rem;
    margin: 0;
    line-height: 1.6;
  }

  .message-meta {
    margin-top: 0.6rem;
    display: flex;
    justify-content: flex-end;
  }

  .message-date {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.25);
  }

  .message-date i {
    font-size: 0.65rem;
  }

  /* ============================================================
     EMPTY STATE
     ============================================================ */
  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
  }

  .empty-state i {
    color: rgba(255, 255, 255, 0.08);
  }

  .empty-state p {
    color: rgba(255, 255, 255, 0.3);
    font-size: 1.1rem;
    font-weight: 500;
    margin: 0;
  }

  .empty-sub {
    display: block;
    color: rgba(255, 255, 255, 0.15);
    font-size: 0.85rem;
    margin-top: 0.4rem;
  }

  /* ============================================================
     MODAL – GLASS STYLE
     ============================================================ */
  .glass-modal {
    background: rgba(20, 20, 40, 0.85) !important;
    backdrop-filter: blur(40px) saturate(1.6);
    -webkit-backdrop-filter: blur(40px) saturate(1.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 2.5rem !important;
    box-shadow: 0 60px 120px rgba(0, 0, 0, 0.7);
    color: #fff;
  }

  .glass-modal .modal-header {
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    padding: 1.5rem 2rem;
  }

  .glass-modal .modal-title {
    color: #fff;
    font-weight: 600;
  }

  .glass-modal .modal-title i {
    color: rgba(108, 99, 255, 0.6);
  }

  .glass-modal .close {
    color: rgba(255, 255, 255, 0.4);
    font-size: 1.8rem;
    opacity: 1;
    text-shadow: none;
    transition: color 0.3s ease;
  }

  .glass-modal .close:hover {
    color: #fff;
  }

  .glass-modal .modal-body {
    padding: 1.5rem 2rem;
  }

  .glass-modal .modal-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    padding: 1.2rem 2rem;
    gap: 0.6rem;
  }

  /* ============================================================
     SHARE MODAL – URL
     ============================================================ */
  .share-url-label {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }

  .share-url-box {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 60px;
    padding: 0.8rem 1.5rem;
    word-break: break-all;
    transition: border-color 0.3s ease;
  }

  .share-url-box:hover {
    border-color: rgba(108, 99, 255, 0.15);
  }

  .share-url-box a {
    color: #a78bfa;
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.3s ease;
  }

  .share-url-box a:hover {
    color: #c4b5fd;
  }

  .btn-copy-link {
    background: rgba(108, 99, 255, 0.08);
    border: 1px solid rgba(108, 99, 255, 0.12);
    color: #a78bfa;
    padding: 0.6rem 2rem;
    border-radius: 60px;
    font-weight: 500;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .btn-copy-link:hover {
    background: rgba(108, 99, 255, 0.15);
    border-color: rgba(108, 99, 255, 0.25);
    color: #c4b5fd;
  }

  .btn-modal-secondary {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.5);
    padding: 0.6rem 1.8rem;
    border-radius: 60px;
    font-weight: 500;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .btn-modal-secondary:hover {
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 768px) {
    .profile-card {
      padding: 2.5rem 1.5rem;
      border-radius: 2.5rem;
    }

    .profile-icon-wrapper,
    .profile-icon {
      width: 100px;
      height: 100px;
    }
    .profile-icon {
      font-size: 3.2rem;
    }

    .messages-header {
      padding: 1.2rem 1.2rem;
    }

    .messages-body {
      padding: 1.2rem;
    }

    .message-item {
      padding: 1rem 1.2rem;
    }

    .glass-modal .modal-header,
    .glass-modal .modal-body,
    .glass-modal .modal-footer {
      padding: 1.2rem 1.2rem;
    }

    .shape-1 {
      width: 180px;
      height: 180px;
    }
    .shape-2 {
      width: 140px;
      height: 140px;
    }
    .shape-3 {
      width: 100px;
      height: 100px;
    }
    .shape-4 {
      width: 80px;
      height: 80px;
    }
    .shape-5 {
      width: 60px;
      height: 60px;
    }
  }

  @media (max-width: 480px) {
    .profile-card {
      padding: 2rem 1rem;
      border-radius: 2rem;
    }

    .profile-icon-wrapper,
    .profile-icon {
      width: 80px;
      height: 80px;
    }
    .profile-icon {
      font-size: 2.8rem;
    }

    .profile-username {
      font-size: 1.4rem;
    }

    .btn-share-profile {
      font-size: 0.85rem;
      padding: 0.6rem 1.6rem;
    }

    .messages-title {
      font-size: 0.95rem;
    }

    .messages-badge {
      font-size: 0.75rem;
      padding: 0.1rem 0.7rem;
    }

    .message-content p {
      font-size: 0.85rem;
    }

    .glass-modal .modal-title {
      font-size: 1rem;
    }

    .btn-modal-secondary {
      padding: 0.5rem 1.2rem;
      font-size: 0.8rem;
    }

    .share-url-box a {
      font-size: 0.8rem;
    }

    .btn-copy-link {
      padding: 0.5rem 1.5rem;
      font-size: 0.8rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {

    // ============================================================
    //  TILT EFFECT
    // ============================================================
    const card = document.getElementById('profileCard');
    const wrapper = document.getElementById('cardWrapperProfile');

    if (card && wrapper) {
      wrapper.addEventListener('mousemove', (e) => {
        const rect = wrapper.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        const rotateX = ((y - rect.height / 2) / rect.height) * -8;
        const rotateY = ((x - rect.width / 2) / rect.width) * 8;

        card.style.transform =
          `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
      });

      wrapper.addEventListener('mouseleave', () => {
        card.style.transform = 'rotateX(0deg) rotateY(0deg)';
      });
    }

    // ============================================================
    //  PARTICLES
    // ============================================================
    const canvas = document.getElementById('particlesCanvasProfile');
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    let w, h;
    let particles = [];
    const PARTICLE_COUNT = 100;

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    }
    window.addEventListener('resize', resize);
    resize();

    class Particle {
      constructor() {
        this.reset();
      }
      reset() {
        this.x = Math.random() * w;
        this.y = Math.random() * h;
        this.size = Math.random() * 2 + 0.6;
        this.speedX = (Math.random() - 0.5) * 0.4;
        this.speedY = (Math.random() - 0.5) * 0.4;
        this.opacity = Math.random() * 0.35 + 0.1;
      }
      update() {
        this.x += this.speedX;
        this.y += this.speedY;
        if (this.x < 0) this.x = w;
        if (this.x > w) this.x = 0;
        if (this.y < 0) this.y = h;
        if (this.y > h) this.y = 0;
      }
      draw() {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255, 255, 255, ${this.opacity})`;
        ctx.fill();
      }
    }

    for (let i = 0; i < PARTICLE_COUNT; i++) {
      particles.push(new Particle());
    }

    let mouse = { x: null, y: null };
    window.addEventListener('mousemove', (e) => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
    });
    window.addEventListener('mouseleave', () => {
      mouse.x = null;
      mouse.y = null;
    });

    function animate() {
      ctx.clearRect(0, 0, w, h);

      particles.forEach((p) => {
        if (mouse.x !== null && mouse.y !== null) {
          const dx = mouse.x - p.x;
          const dy = mouse.y - p.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 160) {
            const force = (160 - dist) / 160 * 0.006;
            p.x += dx * force;
            p.y += dy * force;
          }
        }
        p.update();
        p.draw();
      });

      // connections
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 90) {
            const alpha = (1 - dist / 90) * 0.1;
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(255, 255, 255, ${alpha})`;
            ctx.lineWidth = 0.6;
            ctx.stroke();
          }
        }
      }

      requestAnimationFrame(animate);
    }

    animate();

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        resize();
        particles.forEach(p => p.reset());
      }, 200);
    });

    // ============================================================
    //  COPY LINK BUTTON
    // ============================================================
    const copyBtn = document.getElementById('copyLinkBtn');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        const url = '<%= fullurl + '/user/' + userId %>';
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url).then(() => {
            const original = this.innerHTML;
            this.innerHTML = '<i class="fas fa-check me-2"></i> تم النسخ!';
            setTimeout(() => {
              this.innerHTML = original;
            }, 2000);
          }).catch(() => {
            fallbackCopy(url);
          });
        } else {
          fallbackCopy(url);
        }
      });
    }

    function fallbackCopy(text) {
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      try {
        document.execCommand('copy');
        const btn = document.getElementById('copyLinkBtn');
        if (btn) {
          const original = btn.innerHTML;
          btn.innerHTML = '<i class="fas fa-check me-2"></i> تم النسخ!';
          setTimeout(() => {
            btn.innerHTML = original;
          }, 2000);
        }
      } catch (e) {
        alert('لا يمكن نسخ الرابط، يرجى نسخه يدوياً.');
      }
      document.body.removeChild(textarea);
    }
  });
</script>